{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "crons": [
    { "path": "/api/telegram-daily", "schedule": "30 0 * * *" }
  ],
  "rewrites": [
    { "source": "/", "destination": "/static/index.html" },
    { "source": "/owner", "destination": "/static/index.html" },
    { "source": "/team", "destination": "/static/index.html" },
    { "source": "/tv", "destination": "/static/index.html" }
  ]
}
